{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "declaration": true,
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "alwaysStrict": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "types": [
            "jest",
            "node"
        ]
    },
    "include": [
        "bin/**/*.ts",
        "lib/**/*.ts",
        "test/**/*.ts"
    ]
}